<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">

    <!-- Browser tab title -->
    <title>Contact</title>

    <!-- Connect this page to the CSS file -->
    <link rel="stylesheet" th:href="@{/css/style.css}">

    <script>
        /*
         * This controls the tabs on the Contact page.
         * It hides all sections and only shows the selected one.
         */
        function showTab(tabId) {
            const sections = document.querySelectorAll(".tab-section");
            sections.forEach(section => section.style.display = "none");
            document.getElementById(tabId).style.display = "block";
        }

        /*
         * Show the Add Contact tab first when the page loads.
         */
        window.onload = function () {
            showTab("addContact");
        };
    </script>
</head>
<body>

    <!-- Main page header -->
    <header class="header">
        <h1>Organizer</h1>
    </header>

    <div class="container">

        <!-- Left side navigation menu -->
        <nav class="sidebar">
            <ul>
                <li><a th:href="@{/task}">Task</a></li>
                <li><a th:href="@{/appointment}">Appointment</a></li>
                <li><a th:href="@{/contact}">Contact</a></li>
            </ul>
        </nav>

        <!-- Main page content -->
        <main class="content">
            <h2>Contact</h2>

            <!-- Buttons used like tabs -->
            <div class="tabs">
                <button type="button" onclick="showTab('addContact')">Add Contact</button>
                <button type="button" onclick="showTab('showContact')">Show Contact</button>
                <button type="button" onclick="showTab('searchContact')">Search Contact</button>
            </div>

            <!-- Add Contact tab -->
            <div id="addContact" class="tab-section">
                <h3>Add Contact</h3>

                <!--
                    This form adds a new contact.
                    The address is kept as one field like the project requirements say.
                -->
                <form th:action="@{/contact/add}" method="post">
                    <label for="firstName">First Name:</label><br>
                    <input type="text" id="firstName" name="firstName"><br><br>

                    <label for="lastName">Last Name:</label><br>
                    <input type="text" id="lastName" name="lastName"><br><br>

                    <label for="phoneNumber">Phone Number:</label><br>
                    <input type="text" id="phoneNumber" name="phoneNumber"><br><br>

                    <label for="address">Address:</label><br>
                    <input type="text" id="address" name="address"><br><br>

                    <button type="submit">Add Contact</button>
                </form>
            </div>

            <!-- Show Contact tab -->
            <div id="showContact" class="tab-section" style="display:none;">
                <h3>Show Contacts</h3>

                <!--
                    This dropdown lets the user choose how contacts should be sorted.
                    The controller can use the selected value to sort by first or last name.
                -->
                <form th:action="@{/contact}" method="get">
                    <label for="sortBy">Sort By:</label>
                    <select id="sortBy" name="sortBy">
                        <option value="firstName">First Name</option>
                        <option value="lastName">Last Name</option>
                    </select>
                    <button type="submit">Sort</button>
                </form>

                <!-- Display all contacts -->
                <table>
                    <tr>
                        <th>First Name</th>
                        <th>Last Name</th>
                        <th>Phone Number</th>
                        <th>Address</th>
                    </tr>

                    <tr th:each="contact : ${contacts}">
                        <td th:text="${contact.firstName}"></td>
                        <td th:text="${contact.lastName}"></td>
                        <td th:text="${contact.phoneNumber}"></td>
                        <td th:text="${contact.address}"></td>
                    </tr>
                </table>
            </div>

            <!-- Search Contact tab -->
            <div id="searchContact" class="tab-section" style="display:none;">
                <h3>Search Contact</h3>

                <!--
                    This search allows the user to choose whether to search by first name or last name.
                -->
                <form th:action="@{/contact/search}" method="get">
                    <label for="searchBy">Search By:</label><br>
                    <select id="searchBy" name="searchBy">
                        <option value="firstName">First Name</option>
                        <option value="lastName">Last Name</option>
                    </select><br><br>

                    <label for="contactKeyword">Search Value:</label><br>
                    <input type="text" id="contactKeyword" name="keyword"><br><br>

                    <button type="submit">Search</button>
                </form>

                <h3>Search Results</h3>

                <!--
                    This table shows only the contacts that match the search.
                    I used contactSearchResults to make the model name more clear.
                -->
                <table>
                    <tr>
                        <th>First Name</th>
                        <th>Last Name</th>
                        <th>Phone Number</th>
                        <th>Address</th>
                    </tr>

                    <tr th:each="contact : ${contactSearchResults}">
                        <td th:text="${contact.firstName}"></td>
                        <td th:text="${contact.lastName}"></td>
                        <td th:text="${contact.phoneNumber}"></td>
                        <td th:text="${contact.address}"></td>
                    </tr>
                </table>
            </div>
        </main>
    </div>

    <!-- Footer matches header color -->
    <footer class="footer"></footer>

</body>
</html>