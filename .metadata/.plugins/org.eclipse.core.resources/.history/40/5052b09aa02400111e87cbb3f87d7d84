package com.cs499.organizer.controller;

import org.springframework.stereotype.Controller;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestParam;
import com.cs499.organizer.model.Task;
import com.cs499.organizer.service.TaskService;


@Controller
public class TaskController{
	
	private final TaskService taskService = new TaskService();

	//Task page mapping	
	@GetMapping("/task")
	public String taskPage() {	

		return "task";
	}
	
	//add task button
	@PostMapping("/task/add")
	public String addTask(@RequestParam("taskName") String taskName,@RequestParam("description") String description) {
		Task newTask = new Task(taskService.getNewId(), taskName, description);
		taskService.add(newTask);
		return "task";
	}
	
	@PostMapping("/task/search")
	public String searchTask(@RequestParam("keyword") String keyword) {
		// to be added
		return "task";
	}
}
