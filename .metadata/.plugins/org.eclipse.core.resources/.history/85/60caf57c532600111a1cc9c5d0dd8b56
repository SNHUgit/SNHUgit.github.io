<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>CONTACT_PAGE</title>
	<!-- css code found in style.css -->	
    <link rel="stylesheet" th:href="@{/css/style.css}">
	<!-- optional for tabs-->
	<script th:src="@{/js/tabs.js}"></script>
	<!-- Custom scripts per page-->
	<script th:src="@{/js/contact.js}"></script>
</head>
	<body>
		<!-- header code found in header fragment-->
    	<div th:replace="~{fragments/header :: header}"></div>
    	<div class="container">
		<!-- sidebar code found in sidebar fragment-->	
        <div th:replace="~{fragments/sidebar :: sidebar}"></div>
        	<main class="content">
				<!-- used to keep active tab active-->
				<input type="hidden" id="activeTab" th:value="${activeTab}">
			
				<!--********************************************************-->
				<!--Header Scripts & Sidebar should altered withen fragments-->
				<!--********************************************************-->
				
				<!--Page Title-->
				<h2>Contact</h2>
				
				<!--*********************************************-->
				<!--***************** Tab start *****************-->
				<!--*********************************************-->
				<!--If tabs are used in page-->
				<div class="tab">
					<button type="button" onclick="showTab('showContact')">Show Contact</button>
					<button type="button" onclick="showTab('addContact')">Add Contact</button>
					<button type="button" onclick="showTab('searchContact')">Search Contact</button>
				</div>
				
				<!--Used to display errors thrown -->
				<div th:replace="~{fragments/error :: errorMessage}"></div>

				<!-- Tab content addContact-->
				<div id="addContact" class="tabcontent" style="display:none;">
				  <h3>Add Contact</h3>
			      <form th:action="@{/contact/add}" method="post">
			  		
			         	<label for="addContactFirstName">First Name:</label><br>
			         	<input type="text" id="addContactFirstName" name="addContactFirstName"><br><br>

			          	<label for="addContactLastName">Last Name:</label><br>
			          	<input type="text" id="addContactLastName" name="addContactLastName"><br><br>

			          	<label for="addContactNumber">Number:</label><br>
			          	<input type="text" id="addContactNumber" name="addContactNumber"><br><br>

			          	<label for="addContactAddress">Address:</label><br>
			          	<input type="text" id="addContactAddress" name="addContactAddress"><br><br>

			          	<button type="submit">Add Contact</button>
			      	</form>
			  	</div>
				
				<!-- Tab content ShowContact-->
				
				<div id="showContact" class="tabcontent">
				    <h3>Show Contacts</h3>
				    <table>
				        <tr>
				            <th>First Name</th>
				            <th>Last Name</th>
				            <th>Number</th>
				            <th>Address</th>
							<th>Edit</th>
							<th>Delete</th>
				        </tr>
				        <tr th:each="contact : ${contacts}">
				            <td th:text="${contact.firstName}"></td>
				            <td th:text="${contact.lastName}"></td>
				            <td th:text="${contact.number}"></td>
				            <td th:text="${contact.address}"></td>
							<td>
							    <button type="button"
										th:attr="data-id=${contact.id},data-first-name=${contact.firstName},data-last-name=${contact.lastName},data-number=${contact.number},data-address=${contact.address}"
							            onclick="EditContactFromButton(this)">
							            Edit
							    </button>
							</td>
							<td>
							    <form th:action="@{/contact/delete}" method="post">
							        <input type="hidden" name="id" th:value="${contact.id}">
							        <button type="submit">Delete</button>
							    </form>
							</td>
						</tr>	
				    </table>
				</div>
				
				<!-- Tab content edit Contact-->
				
				<div id="editContact" class="tabcontent" style="display:none;">
				    <h3>Edit Contact</h3>

				    <form th:action="@{/contact/edit}" method="post">
				        <input type="hidden" id="editContactId" name="id">

				        <label for="editContactFirstName">First Name:</label><br>
				        <input type="text" id="editContactFirstName" name="editContactFirstName"><br><br>

				        <label for="editContactLastName">Last Name:</label><br>
				        <input type="text" id="editContactLastName" name="editContactLastName"><br><br>

				        <label for="editContactNumber">Number:</label><br>
				        <input type="text" id="editContactNumber" name="editContactNumber"><br><br>

				        <label for="editContactAddress">Address:</label><br>
				        <input type="text" id="editContactAddress" name="editContactAddress"><br><br>

				        <button type="submit">Save</button>
				    </form>
				</div>
				
				<!-- Tab content search contact-->

				<div id="searchContact" class="tabcontent" style="display:none;">
				    <h3>Search Contact</h3>

					<form th:action="@{/contact/search}" method="get">
					    <label for="searchContactInput">Search by first or last name:</label><br>
					    <input type="text" id="searchContactInput" name="searchContact"><br><br>
					    <button type="submit">Search</button>
					</form>

				    <h3>Search Results</h3>
					<p th:if="${searchContactValue != null}">
					    You searched for: <span th:text="${searchContactValue}"></span>
					</p>
				    <table>
				        <tr>
				            <th>First Name</th>
				            <th>Last Name</th>
				            <th>Number</th>
				            <th>Address</th>
							<th>Edit</th>
							<th>Delete</th>
				        </tr>

				        <tr th:each="contact : ${contactSearchResults}">
				            <td th:text="${contact.firstName}"></td>
				            <td th:text="${contact.lastName}"></td>
				            <td th:text="${contact.number}"></td>
				            <td th:text="${contact.address}"></td>
							<td>
							    <button type="button"
										th:attr="data-id=${contact.id},data-first-name=${contact.firstName},data-last-name=${contact.lastName},data-number=${contact.number},data-address=${contact.address}"
							            onclick="EditContactFromButton(this)">
							            Edit
							    </button>
							</td>
							<td>
							    <form th:action="@{/contact/delete}" method="post">
							        <input type="hidden" name="id" th:value="${contact.id}">
							        <button type="submit">Delete</button>
							    </form>
							</td>
				        </tr>
				    </table>
				</div>

				<!--*********************************************-->
				<!--****************** Tab end ******************-->
				<!--*********************************************-->
				
				<!--*********************************************-->
				<!--Code below should be altered withen fragments-->
				<!--*********************************************-->
			</main>
    	</div>
		<!-- footer code found in footer fragment-->	
		<div th:replace="~{fragments/footer :: footer}"></div>
	</body>
</html>