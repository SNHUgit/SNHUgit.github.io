<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>TEMPLATE_PAGE</title>
	<!-- css code found in style.css -->	
    <link rel="stylesheet" th:href="@{/css/style.css}">
	<!-- optional for tabs-->
	<script th:src="@{/js/tabs.js}"></script>
	<!-- Custom scripts per page-->
	<script th:src="@{/js/task.js}"></script>
</head>
	<body>
		<!-- header code found in header fragment-->
    	<div th:replace="fragments/header :: header"></div>
    	<div class="container">
		<!-- sidebar code found in sidebar fragment-->	
        <div th:replace="fragments/sidebar :: sidebar"></div>
        	<main class="content">
				<!-- used to keep active tab active-->
				<input type="hidden" id="activeTab" th:value="${activeTab}">
				
				<!--*********************************************-->
				<!--Code above should be altered withen fragments-->
				<!--*********************************************-->
				
				<!--Page Title-->
				<h2>Page Title</h2>
				
				<!--*********************************************-->
				<!--***************** Tab start *****************-->
				<!--*********************************************-->
				<!--If tabs are used in page-->
				<div class="tab">
				    <button type="button" onclick="showTab('tab1label')">tab 1 text</button>
				    <button type="button" onclick="showTab('tab2label')">tab 2 text</button>
				    <button type="button" onclick="showTab('tab3label')">tab 3 text</button>
				</div>
				
				<!-- Tab content -->
				<div id="tab1label" class="tabcontent" style="display:none;">
				  <h3>Tab Title</h3>
				  <p>Tab content.</p>
				</div>
				<!--*********************************************-->
				<!--****************** Tab end ******************-->
				<!--*********************************************-->
				
				<!--*********************************************-->
				<!--***************** Form start ****************-->
				<!--*********************************************-->
				
				<form th:action="@{/controller/location}" method="post">					
					<label for="ID_USED_BY_HTML">TEXT_FOR_INPUT:</label><br>
					<input type="text" id="ID_USED_BY_HTML" name="ID_USED_BY_CONTROLLER"><br><br>
				</form>
				
				<!--*********************************************-->
				<!--****************** Form end *****************-->
				<!--*********************************************-->
				
				
				<!--*********************************************-->
				<!--Code below should be altered withen fragments-->.
				<!--*********************************************-->
			</main>
    	</div>
		<!-- sidebar code found in footer fragment-->	
		<div th:replace="fragments/footer :: footer"></div>
	</body>
</html>