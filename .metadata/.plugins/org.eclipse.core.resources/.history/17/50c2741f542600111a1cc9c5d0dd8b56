<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<body>
    <div th:fragment="messages">
        <div th:if="${errorMessage}" class="error-box">
            <p th:text="${errorMessage}"></p>
        </div>

        <div th:if="${successMessage}" class="success-box">
            <p th:text="${successMessage}"></p>
        </div>
    </div>
</body>
</html>